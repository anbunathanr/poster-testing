# Environment Configuration
NODE_ENV=development
AWS_REGION=us-east-1

# AWS Credentials (for local development only)
# Use AWS CLI or IAM roles in production
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# JWT Secret (generate a secure random string for each environment)
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# DynamoDB Tables
DYNAMODB_USERS_TABLE=ai-testing-users-dev
DYNAMODB_TESTS_TABLE=ai-testing-tests-dev
DYNAMODB_TEST_RESULTS_TABLE=ai-testing-results-dev
DYNAMODB_ENVIRONMENTS_TABLE=ai-testing-environments-dev

# S3 Buckets
S3_EVIDENCE_BUCKET=ai-testing-evidence-dev

# Amazon Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v2:0
BEDROCK_REGION=us-east-1
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.7

# JWT Configuration
JWT_EXPIRES_IN=3600
JWT_ALGORITHM=HS256

# API Gateway (for local testing)
API_GATEWAY_URL=http://localhost:3000

# SNS Configuration
SNS_NOTIFICATION_TOPIC=ai-testing-notifications-dev

# CloudWatch Configuration
CLOUDWATCH_LOG_RETENTION_DAYS=30
CLOUDWATCH_METRICS_NAMESPACE=AITestingPlatform/Dev

# Lambda Configuration
LAMBDA_AUTH_MEMORY_SIZE=256
LAMBDA_AUTH_TIMEOUT=10
LAMBDA_TEST_GEN_MEMORY_SIZE=512
LAMBDA_TEST_GEN_TIMEOUT=30
LAMBDA_TEST_EXEC_MEMORY_SIZE=2048
LAMBDA_TEST_EXEC_TIMEOUT=300
LAMBDA_STORAGE_MEMORY_SIZE=512
LAMBDA_STORAGE_TIMEOUT=30
LAMBDA_REPORT_MEMORY_SIZE=512
LAMBDA_REPORT_TIMEOUT=30

# S3 Presigned URL Expiration (in seconds)
S3_PRESIGNED_URL_EXPIRATION=3600

# API Rate Limiting
API_RATE_LIMIT=1000
API_BURST_LIMIT=2000

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=10

# Playwright Configuration (for test execution)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# Logging
LOG_LEVEL=info
