{
  "name": "ai-testing-automation-platform",
  "version": "1.0.0",
  "description": "AI-powered automated testing SaaS platform for Social Media Poster applications",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:e2e": "jest --selectProjects e2e",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "cdk": "cd infrastructure && cdk",
    "cdk:synth": "cd infrastructure && cdk synth",
    "cdk:deploy:dev": "cd infrastructure && cdk deploy --context environment=dev",
    "cdk:deploy:staging": "cd infrastructure && cdk deploy --context environment=staging",
    "cdk:deploy:prod": "cd infrastructure && cdk deploy --context environment=prod --require-approval broadening",
    "cdk:diff": "cd infrastructure && cdk diff",
    "cdk:destroy:dev": "cd infrastructure && cdk destroy --context environment=dev",
    "sam:validate": "sam validate",
    "sam:build": "npm run build && sam build",
    "sam:start": "npm run build && sam local start-api",
    "sam:start:debug": "npm run build && sam local start-api -d 5858",
    "sam:start:env": "npm run build && sam local start-api --env-vars env.json",
    "sam:invoke:auth": "sam local invoke AuthFunction -e events/auth-login.json",
    "sam:invoke:testgen": "sam local invoke TestGenerationFunction -e events/test-generate.json --env-vars env.json",
    "sam:invoke:testexec": "sam local invoke TestExecutionFunction -e events/test-execute.json --env-vars env.json",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "local:setup": "docker-compose up -d && sleep 5 && chmod +x scripts/create-local-tables.sh && ./scripts/create-local-tables.sh && chmod +x scripts/create-local-s3.sh && ./scripts/create-local-s3.sh",
    "local:setup:tables": "node scripts/create-local-tables.js || echo 'Tables setup complete'",
    "local:dev": "npm run build && sam local start-api --env-vars env.json",
    "local:clean": "docker-compose down -v",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test:smoke": "echo 'Smoke tests not yet implemented' && exit 0"
  },
  "keywords": [
    "testing",
    "automation",
    "ai",
    "playwright",
    "aws",
    "lambda"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.490.0",
    "@aws-sdk/client-cloudwatch": "^3.993.0",
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/client-secrets-manager": "^3.490.0",
    "@aws-sdk/client-sns": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "playwright-aws-lambda": "^0.10.0",
    "playwright-core": "^1.40.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^18.19.130",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "aws-cdk-lib": "^2.238.0",
    "aws-sdk-client-mock": "^4.1.0",
    "constructs": "^10.4.5",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
